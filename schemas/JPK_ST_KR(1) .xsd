	<xsd:element name="JPK">
		<xsd:annotation>
			<xsd:documentation>Jednolity plik kontrolny dla ewidencji środków trwałych oraz wartości niematerialnych i prawnych dla podmiotów prowadzących księgi rachunkowe</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:sequence>
				<xsd:element name="Naglowek" type="tns:TNaglowek">
					<xsd:annotation>
						<xsd:documentation>Nagłówek JPK_ST_KR</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<xsd:element name="Podmiot1">
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="IdentyfikatorPodmiotu" type="etd:TIdentyfikatorOsobyNiefizycznej">
								<xsd:annotation>
									<xsd:documentation>Dane identyfikujące podmiot</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="Adres">
								<xsd:annotation>
									<xsd:documentation>Adres podmiotu</xsd:documentation>
								</xsd:annotation>
								<xsd:complexType>
									<xsd:choice>
										<xsd:element name="AdresPol" type="etd:TAdresPolski1">
											<xsd:annotation>
												<xsd:documentation>Adres polski</xsd:documentation>
											</xsd:annotation>
										</xsd:element>
										<xsd:element name="AdresZagr" type="etd:TAdresZagraniczny">
											<xsd:annotation>
												<xsd:documentation>Adres zagraniczny</xsd:documentation>
											</xsd:annotation>
										</xsd:element>
									</xsd:choice>
								</xsd:complexType>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="ST_KR" maxOccurs="unbounded">
					<xsd:annotation>
						<xsd:documentation>Ewidencja środków trwałych oraz wartości niematerialnych i prawnych</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="E_1" type="tns:TZnakowyJPK">
								<xsd:annotation>
									<xsd:documentation>Numer inwentarzowy</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:choice>
								<xsd:element name="E_2" type="etd:TData">
									<xsd:annotation>
										<xsd:documentation>Data nabycia/wytworzenia środka trwałego</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="E_3" type="etd:TData">
									<xsd:annotation>
										<xsd:documentation>Data nabycia wartości niematerialnej i prawnej lub zakończenia prac rozwojowych zaliczanych do wartości niematerialnych i prawnych</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
							</xsd:choice>
							<xsd:element name="E_4" type="etd:TData">
								<xsd:annotation>
									<xsd:documentation>Data przyjęcia środka trwałego lub wartości niematerialnej i prawnej do używania/data ujęcia w księgach rachunkowych udokumentowanego przyjęcia zakończonych prac rozwojowych jako obiektu inwentarzowego WNiP</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_5" type="tns:TZnakowyJPK">
								<xsd:annotation>
									<xsd:documentation>Określenie numeru dokumentu (OT), na podstawie którego wprowadzono środek trwały lub WNiP</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_6" type="tns:TNabycia">
								<xsd:annotation>
									<xsd:documentation>Określenie rodzaju dokumentu stwierdzającego nabycie/wytworzenie</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_7" type="tns:TZnakowyJPK">
								<xsd:annotation>
									<xsd:documentation>Nazwa środka trwałego lub wartości niematerialnej i prawnej</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_8" type="tns:TZnakowyJPK" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Symbol klasyfikacji środków trwałych (KŚT)</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:sequence>
								<xsd:element name="E_9_1" type="tns:TMetodaAmoryzacji">
									<xsd:annotation>
										<xsd:documentation>Metoda amortyzacji podatkowa </xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="E_9_2" type="tns:TMetodaAmoryzacji" minOccurs="0">
									<xsd:annotation>
										<xsd:documentation>Metoda amortyzacji podatkowa</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="E_9_3" type="tns:TMetodaAmoryzacji" minOccurs="0">
									<xsd:annotation>
										<xsd:documentation>Metoda amortyzacji podatkowa</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
							</xsd:sequence>
							<xsd:sequence>
								<xsd:element name="E_10A" type="etd:TProcentowy">
									<xsd:annotation>
										<xsd:documentation>Stawka amortyzacyjna podatkowa podstawowa (procentowa) wynikająca z wykazu stawek amortyzacyjnych</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="E_10B" type="tns:TKwotowy">
									<xsd:annotation>
										<xsd:documentation>Stawka amortyzacyjna podatkowa podstawowa (kwotowa), w tym wartość amortyzacji jednorazowej</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
							</xsd:sequence>
							<xsd:element name="E_11" type="etd:TProcentowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Stawka amortyzacyjna podatkowa po korekcie (procentowa). Stawka stosowana przez podatnika, jeżeli jest inna niż wynikająca z wykazu stawek amortyzacyjnych (E_10A)</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_12" type="tns:TKwotowy">
								<xsd:annotation>
									<xsd:documentation>Wartość początkowa podatkowa</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_13" type="tns:TKwotowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Zaktualizowana wartość początkowa podatkowa (art. 15 ust. 5 CIT lub art. 22o ust. 1 PIT)</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_14" type="tns:TKwotowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Zaktualizowana kwota odpisów amortyzacyjnych podatkowa (art. 15 ust. 5 CIT lub art. 22o ust. 1 PIT)</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_15" type="tns:TKwotowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Zmiana wartości początkowej podatkowej (z powodów innych niż na podstawie art. 15 ust. 5 CIT lub art. 22o ust. 1 PIT):
(+) zwiększenie;
(-) zmniejszenie</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_16" type="tns:TKwotowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Kwota odpisów amortyzacyjnych wg stanu na ostatni dzień roku poprzedzającego rozpoczęcie ewidencji (art. 16g ust. 20-22 ustawy CIT, art. 22n ust. 5 PIT)</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_17" type="tns:TOdpis">
								<xsd:annotation>
									<xsd:documentation>Częstotliwość odpisu</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_18" type="tns:TKwotowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Wysokość odpisu amortyzacyjnego podatkowego - niestanowiącego kosztu uzyskania przychodu dla danego roku podatkowego/obrotowego</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_19" type="tns:TKwotowy">
								<xsd:annotation>
									<xsd:documentation>Suma odpisów amortyzacyjnych podatkowych dla danego roku podatkowego/obrotowego</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_20" type="tns:TKwotowy">
								<xsd:annotation>
									<xsd:documentation>Suma odpisów amortyzacyjnych podatkowych narastająco w całym okresie amortyzacji</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_21" type="tns:TKwotowy">
								<xsd:annotation>
									<xsd:documentation>Wartość początkowa rachunkowa</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_22" type="tns:TKwotowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Zaktualizowana wartość początkowa rachunkowa (na podstawie art. 31 ust. 3 UoR)</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_23" type="tns:TKwotowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Zaktualizowana kwota odpisów amortyzacyjnych lub umorzeniowych rachunkowa (na podstawie art. 31 ust. 3 UoR)</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_24" type="tns:TKwotowy" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>Zmiana wartości początkowej rachunkowej (z powodów innych niż na podstawie art. 31 ust. 3 UoR):
(+) zwiększenie;
(-) zmniejszenie</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:sequence>
								<xsd:element name="E_25A" type="etd:TProcentowy">
									<xsd:annotation>
										<xsd:documentation>Stawka amortyzacyjna rachunkowa (procentowa)</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="E_25B" type="tns:TKwotowy">
									<xsd:annotation>
										<xsd:documentation>Stawka amortyzacyjna rachunkowa (kwotowa)</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
							</xsd:sequence>
							<xsd:element name="E_26" type="tns:TKwotowy">
								<xsd:annotation>
									<xsd:documentation>Suma odpisów amortyzacyjnych rachunkowych dla danego roku podatkowego/obrotowego</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="E_27" type="tns:TKwotowy">
								<xsd:annotation>
									<xsd:documentation>Suma odpisów amortyzacyjnych rachunkowych narastająco w całym okresie amortyzacji</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:sequence minOccurs="0">
								<xsd:element name="E_28" type="etd:TData">
									<xsd:annotation>
										<xsd:documentation>Data wykreślenia z ewidencji</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="E_29" type="tns:TWykreslenie">
									<xsd:annotation>
										<xsd:documentation>Przyczyna wykreślenia z ewidencji (tytuł likwidacji)</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="E_30" type="tns:TZnakowyJPK">
									<xsd:annotation>
										<xsd:documentation>Określenie numeru dokumentu stwierdzającego wykreślenie z ewidencji</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="KSeF" minOccurs="0">
									<xsd:complexType>
										<xsd:sequence>
											<xsd:element name="E_31" type="tns:TNumerKSeF" maxOccurs="unbounded">
												<xsd:annotation>
													<xsd:documentation>Wskazanie numeru dokumentu KSeF stwierdzającego zbycie</xsd:documentation>
												</xsd:annotation>
											</xsd:element>
										</xsd:sequence>
									</xsd:complexType>
								</xsd:element>
							</xsd:sequence>
							<xsd:element name="E_32" type="etd:TWybor1_2" default="2">
								<xsd:annotation>
									<xsd:documentation>Reklasyfikacja (zmiana klasyfikacji KŚT w trakcie roku podatkowego/obrotowego): 1 - TAK; 2 -  NIE</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
			</xsd:sequence>
		</xsd:complexType>
	</xsd:element>
</xsd:schema>
